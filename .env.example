# ═══════════════════════════════════════════════
# TorFlix — Configuration Environnement
# Copier ce fichier en .env et modifier les valeurs
# ═══════════════════════════════════════════════

# ── Base de données ──
DB_USER=torflix
DB_PASSWORD=torflix_secret_2026

# ── JWT (CHANGER EN PRODUCTION !) ──
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_very_long_and_random

# ── Chiffrement des identifiants torrent (32 chars) ──
ENCRYPTION_KEY=change_me_32_characters_long_key!

# ── TMDB API (obtenir sur https://www.themoviedb.org/settings/api) ──
TMDB_API_KEY=your_tmdb_api_key_here

# ── Proxy (optionnel) ──
PROXY_URL=
# PROXY_URL=socks5://user:pass@proxy-host:1080

# ── VPN (optionnel) ──
VPN_ENABLED=false
VPN_TYPE=wireguard
