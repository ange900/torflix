# Node Environment
NODE_ENV=development

# Server Configuration
PORT=4000

# Database Configuration
DATABASE_URL=postgresql://torflixuser:torflixpass@postgres:5432/torflix

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
# Generate secure random strings for production (min 64 characters)
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production-min-64-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-64-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Password Reset (in production, configure email service)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
